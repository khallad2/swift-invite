# SwiftInvite Environment Variables Example

# The base URL of the application. Set to localhost for local development, 
# or your machine's local network IP (e.g. http://192.168.1.100:3000) for local mobile testing.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Toggle to turn on/off new account registrations (set to true to block signups)
NEXT_PUBLIC_DISABLE_SIGNUP=false

# Your Resend API key to enable live email delivery of invitations (e.g. re_abc123)
RESEND_API_KEY=your_resend_api_key_here

# NextAuth configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_key_here

# Database individual variables (used as reference/helpers)
DB_SERVER_URL=your_mysql_host
DB_NAME=your_mysql_database_name
DB_USER=your_mysql_user
DB_PASS=your_mysql_password

# Database connection string (MySQL format)
# For local Docker development: mysql://swift_dev_user:swift_dev_password@db:3306/swiftinvite_dev
# For production (e.g. Hostinger): mysql://${DB_USER}:${DB_PASS}@${DB_SERVER_URL}:3306/${DB_NAME}
DATABASE_URL=mysql://db_user:db_password@hostname:3306/db_name